    "semi": {
      // 蓄力模式
      // auto - 按住扳机蓄力，蓄满后自动发射
      // hold - 按住扳机蓄力，直到松开扳机才发射（如果满足阈值）
      // delay - 按下扳机后自动进行蓄力，蓄满后自动发射，无法取消
      "type": "auto",
