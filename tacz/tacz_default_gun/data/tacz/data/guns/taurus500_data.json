      "increase_per_tick": 0.1,
      "decrease_per_tick": 0.1,
      // 开火后削减的蓄力进度
      // 开火模式为全自动且蓄力模式为auto时，如果不重置的话第一发完成蓄力后可以按住扳机持续开火
      // 蓄力模式为hold时，如果开火后蓄力进度仍然大于阈值，即使松开扳机也会不受控制的持续开火（如果大于阈值的话不会触发decrease_per_tick）
      // 蓄力模式为delay时，此值无效（始终重置为0）
      "decrease_on_fire": 0.5,
      // 最大蓄力进度
      "max_charge": 0.5,
      // 开火阈值，蓄力至少进度达到此值时允许开火(仅hold模式生效)
      "fire_threshold": 0.5,
      // 在射击冷却期间，是否可以进行蓄力
      "charge_during_cooldown": false
    }
